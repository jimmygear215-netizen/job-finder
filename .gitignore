# Ignore entire project except what's in the_working
# Except for these root files if needed:
.vercel/
node_modules/
__pycache__/
*.pyc

# Keep only the working folder
!the_working/.gitkeep
!the_working/app.py
!the_working/index.html
!the_working/static/*
!the_working/templates/*
!the_working/requirements.txt
!the_working/README.md
